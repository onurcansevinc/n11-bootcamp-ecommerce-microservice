{
  "realm": "ecommerce",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access to the e-commerce platform"
      },
      {
        "name": "catalog-manager",
        "description": "Can manage product and category data"
      }
    ]
  },
  "clientScopes": [
    {
      "name": "products.write",
      "description": "Write access to product APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": []
    },
    {
      "name": "categories.write",
      "description": "Write access to category APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": []
    },
    {
      "name": "inventory.read",
      "description": "Read access to inventory APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": []
    },
    {
      "name": "inventory.write",
      "description": "Write access to inventory APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": []
    },
    {
      "name": "orders.write",
      "description": "Internal write access to order APIs",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": []
    }
  ],
  "clients": [
    {
      "clientId": "storefront-web",
      "name": "Storefront Web Client",
      "description": "React storefront single-page application client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "ecommerce-api",
      "name": "E-Commerce API Local Client",
      "description": "Local development client for interactive API access",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "products.write",
        "categories.write",
        "inventory.read",
        "inventory.write",
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "service-internal",
      "name": "Internal Service Client",
      "description": "Service-to-service internal client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "change-me-service-client-secret",
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": false,
      "defaultClientScopes": [
        "profile",
        "email",
        "roles",
        "inventory.read",
        "inventory.write",
        "orders.write"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "admin-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "catalog-manager",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Catalog",
      "lastName": "Manager",
      "credentials": [
        {
          "type": "password",
          "value": "catalog123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "catalog-manager"
      ]
    },
    {
      "username": "customer-user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Customer",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "customer123",
          "temporary": false
        }
      ]
    }
  ]
}
